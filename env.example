# Variables d'environnement pour Yamdata Admin

# URL de l'application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Configuration Supabase
NEXT_PUBLIC_SUPABASE_URL=votre_url_supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_clé_anon_supabase
# Clé de service pour les opérations d'administration (ne pas préfixer par NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=votre_clé_service_role_supabase

# Configuration de l'administrateur initial
NEXT_PUBLIC_ADMIN_EMAIL=admin@yamdata.com
NEXT_PUBLIC_ADMIN_PHONE=+22600000000
# Ne pas exposer le mot de passe en tant que variable publique (NEXT_PUBLIC_)
ADMIN_PASSWORD=MotDePasseTrèsSecurisé!

# Clés secrètes pour l'initialisation de l'administrateur
# Ces valeurs doivent être identiques et générées de manière aléatoire
ADMIN_INIT_SECRET=générer_une_clé_secrète_aléatoire
ADMIN_INIT_SECRET_VERIFY=générer_une_clé_secrète_aléatoire 